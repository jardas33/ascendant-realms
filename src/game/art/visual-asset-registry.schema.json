{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ascendant-realms.local/schemas/visual-asset-registry.schema.json",
  "title": "Ascendant Realms Visual Asset Registry",
  "description": "Reference-only art-planning registry for future visual candidates. This schema does not approve runtime integration.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schemaVersion",
    "checkpoint",
    "status",
    "createdAt",
    "updatedAt",
    "sourceManifest",
    "generatedAssetsIncluded",
    "runtimeIntegrationApproved",
    "registryPurpose",
    "fieldDefinitions",
    "reviewStates",
    "assets"
  ],
  "properties": {
    "schemaVersion": { "const": 1 },
    "checkpoint": { "type": "string", "minLength": 1 },
    "status": { "const": "reference-registry-only" },
    "createdAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "updatedAt": { "type": "string", "pattern": "^\\d{4}-\\d{2}-\\d{2}$" },
    "sourceManifest": { "const": "docs/V088_VERTICAL_SLICE_ASSET_MANIFEST.json" },
    "generatedAssetsIncluded": { "const": false },
    "runtimeIntegrationApproved": { "const": false },
    "registryPurpose": { "type": "string", "minLength": 1 },
    "fieldDefinitions": {
      "type": "array",
      "items": { "type": "string", "minLength": 1 },
      "minItems": 1,
      "uniqueItems": true
    },
    "reviewStates": {
      "type": "array",
      "items": {
        "enum": [
          "not-created",
          "candidate-ready",
          "style-approved",
          "revision-requested",
          "rejected",
          "runtime-candidate-approved",
          "runtime-integrated"
        ]
      },
      "minItems": 7,
      "maxItems": 7,
      "uniqueItems": true
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "assetId",
          "category",
          "faction",
          "runtimeSlot",
          "conceptStage",
          "reviewStatus",
          "reviewState",
          "source",
          "license",
          "generatedBy",
          "promptVersion",
          "promptTemplateReference",
          "negativePromptReference",
          "visualConsistencyNotes",
          "approvalStatus",
          "integrationReadiness",
          "sourceLicensePosture",
          "protectedIpPosture",
          "reviewWorkspace",
          "replacementHistory"
        ],
        "properties": {
          "assetId": { "type": "string", "pattern": "^v088_[a-z0-9_]+$" },
          "category": { "type": "string", "minLength": 1 },
          "faction": { "type": "string", "minLength": 1 },
          "runtimeSlot": { "type": "string", "pattern": "not-runtime" },
          "conceptStage": { "type": "string", "minLength": 1 },
          "reviewStatus": { "type": "string", "minLength": 1 },
          "reviewState": {
            "enum": [
              "not-created",
              "candidate-ready",
              "style-approved",
              "revision-requested",
              "rejected",
              "runtime-candidate-approved",
              "runtime-integrated"
            ]
          },
          "source": { "type": "string", "minLength": 1 },
          "license": { "type": "string", "minLength": 1 },
          "generatedBy": { "type": "string", "minLength": 1 },
          "promptVersion": { "type": "string", "minLength": 1 },
          "promptTemplateReference": { "type": "string", "minLength": 1 },
          "negativePromptReference": { "type": "string", "minLength": 1 },
          "visualConsistencyNotes": { "type": "string", "minLength": 1 },
          "approvalStatus": { "type": "string", "minLength": 1 },
          "integrationReadiness": { "type": "string", "pattern": "not-ready|future-runtime|integrated" },
          "sourceLicensePosture": { "type": "string", "minLength": 1 },
          "protectedIpPosture": { "type": "string", "minLength": 1 },
          "reviewWorkspace": {
            "type": "object",
            "additionalProperties": false,
            "required": ["candidateDirectory", "contactSheetDirectory", "reportDirectory"],
            "properties": {
              "candidateDirectory": { "type": "string", "pattern": "^artifacts/art-review/candidates/" },
              "contactSheetDirectory": { "type": "string", "pattern": "^artifacts/art-review/contact-sheets/" },
              "reportDirectory": { "type": "string", "pattern": "^artifacts/art-review/reports/" }
            }
          },
          "replacementHistory": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
