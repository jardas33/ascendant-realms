{
  "name": "ascendant-realms",
  "version": "0.1.0",
  "private": true,
  "description": "A tiny, expandable RTS/RPG hybrid prototype built with Phaser 3, TypeScript, and Vite.",
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "tsc -p tsconfig.json && vite build",
    "build:playtest": "tsc -p tsconfig.json && vite build --base ./",
    "package:playtest": "npm run build:playtest && tsx tools/packagePlaytestBuild.ts",
    "verify:playtest-package": "tsx tools/verifyPlaytestPackage.ts",
    "build:analyze": "tsc -p tsconfig.json && vite build --mode analyze",
    "preview": "vite preview --host 0.0.0.0",
    "preview:hosted": "vite preview --host 127.0.0.1 --port 5173 --strictPort",
    "smoke:preview": "tsx tools/smokePreview.ts",
    "test": "vitest run",
    "validate:content": "tsx tools/validateContent.ts",
    "validate:art-intake": "tsx tools/art-intake/validateArtIntake.ts",
    "validate:runtime-art-slots": "tsx tools/runtime-art-slots/validateRuntimeArtSlots.ts",
    "art:packet:salto-slice": "tsx tools/salto-slice/generateSaltoSlicePacket.ts",
    "art:review:init": "tsx tools/art-review/initArtReviewWorkspace.ts",
    "art:review:validate": "tsx tools/art-review/validateArtReview.ts",
    "art:review:contact-sheet": "tsx tools/art-review/generateArtReviewContactSheet.ts",
    "art:review:report": "tsx tools/art-review/generateArtReviewReport.ts",
    "export:portable-content": "tsx tools/exportPortableContent.ts",
    "validate:portable-content": "tsx tools/validatePortableContent.ts",
    "export:desktop-spike-fixture": "tsx tools/exportDesktopSpikeFixture.ts",
    "validate:desktop-spike-fixture": "tsx tools/validateDesktopSpikeFixture.ts",
    "godot:doctor": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/doctorGodotWindows.ps1",
    "godot:bootstrap:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/bootstrapGodotWindows.ps1",
    "godot:fixture:export": "npm run export:desktop-spike-fixture",
    "godot:fixture:validate": "npm run validate:desktop-spike-fixture",
    "godot:scene:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/generateGodotSaltoScene.ps1",
    "godot:validate": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotValidation.ps1",
    "godot:test": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotTests.ps1",
    "godot:benchmark": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotBenchmark.ps1",
    "godot:export:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/exportGodotWindows.ps1",
    "godot:package:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/packageGodotWindows.ps1",
    "godot:launch:review": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/launchGodotReviewWindows.ps1",
    "godot:launch:private-harness": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/launchGodotPrivateHarnessWindows.ps1",
    "godot:launch:player-slice": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/launchGodotPlayerSliceWindows.ps1",
    "godot:headed:smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotHeadedSmoke.ps1",
    "godot:capture:review": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/captureGodotReviewWindows.ps1",
    "godot:capture:player-slice": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/captureGodotPlayerSliceWindows.ps1",
    "godot:audit:player-slice": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/auditGodotPlayerSliceWindows.ps1",
    "godot:validate:player-slice": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/validateGodotPlayerSlice.ps1",
    "godot:validate:real-input": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotRealInputSmokeWindows.ps1",
    "godot:headed:real-input-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotRealInputSmokeWindows.ps1",
    "godot:validate:site-semantics": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotSiteSemanticsSmokeWindows.ps1",
    "godot:headed:site-semantics-smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotSiteSemanticsSmokeWindows.ps1",
    "godot:scorecard": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotBenchmark.ps1 -ScorecardOnly",
    "godot:all": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotAll.ps1",
    "godot:fresh-checkout:validate": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/validateGodotFreshCheckout.ps1",
    "godot:ci-style:windows": "powershell -NoProfile -ExecutionPolicy Bypass -File tools/godot/runGodotCiStyleWindows.ps1",
    "test:save-translation-contract": "tsx tools/testSaveTranslationContract.ts",
    "test:e2e": "playwright test",
    "test:e2e:smoke:fast": "playwright test tests/e2e/smoke.spec.ts --grep @ci-fast --reporter=line",
    "test:e2e:smoke": "playwright test tests/e2e/smoke.spec.ts --reporter=line",
    "test:e2e:layout": "playwright test tests/e2e/layout.spec.ts --reporter=line",
    "test:e2e:deep": "playwright test tests/e2e/deep-flow.spec.ts --reporter=line",
    "test:e2e:release": "playwright test --reporter=line",
    "test:e2e:release:shard1": "playwright test --reporter=line --shard=1/2",
    "test:e2e:release:shard2": "playwright test --reporter=line --shard=2/2",
    "test:e2e:release:shard1of3": "playwright test --reporter=line --shard=1/3",
    "test:e2e:release:shard2of3": "playwright test --reporter=line --shard=2/3",
    "test:e2e:release:shard3of3": "playwright test --reporter=line --shard=3/3",
    "test:e2e:release:hosted:deep-meta": "playwright test --config=playwright.hosted-release.config.ts tests/e2e/deep-flow.spec.ts --grep @hosted-deep-meta --reporter=line",
    "test:e2e:release:hosted:deep-battle": "playwright test --config=playwright.hosted-release.config.ts tests/e2e/deep-flow.spec.ts --grep @hosted-deep-battle --reporter=line",
    "test:e2e:release:hosted:deep-campaign-pressure": "playwright test --config=playwright.hosted-release.config.ts tests/e2e/deep-flow.spec.ts tests/e2e/enemy-pressure.spec.ts --grep @hosted-deep-campaign --reporter=line",
    "test:e2e:release:hosted:layout-core": "playwright test --config=playwright.hosted-release.config.ts tests/e2e/layout.spec.ts --grep @hosted-layout-core --reporter=line",
    "test:e2e:release:hosted:layout-cinderfen": "playwright test --config=playwright.hosted-release.config.ts tests/e2e/layout.spec.ts --grep @hosted-layout-cinderfen --reporter=line",
    "test:e2e:release:hosted:smoke": "playwright test --config=playwright.hosted-release.config.ts tests/e2e/smoke.spec.ts --reporter=line",
    "test:e2e:headed": "playwright test --headed",
    "visual:qa": "playwright test --config=playwright.visual-qa.config.ts --reporter=line",
    "visual:review-pack": "tsx tools/generateVisualReviewPack.ts",
    "perf:profile:private": "tsx tools/profilePrivatePerformance.ts",
    "perf:report:private": "tsx tools/reportPrivatePerformance.ts",
    "benchmark:battle:smoke": "tsx tools/runRepresentativeBattleBenchmark.ts --profile=smoke",
    "benchmark:battle:representative": "tsx tools/runRepresentativeBattleBenchmark.ts --profile=representative",
    "benchmark:battle:stress": "tsx tools/runRepresentativeBattleBenchmark.ts --profile=stress",
    "benchmark:battle:report": "tsx tools/reportRepresentativeBattleBenchmark.ts",
    "perf:trusted:preview": "tsx tools/runTrustedBrowserBenchmark.ts --mode=preview --cases=mode-preview-headless,baseline",
    "perf:trusted:dev": "tsx tools/runTrustedBrowserBenchmark.ts --mode=dev --cases=mode-dev-headless",
    "perf:trusted:manual-template": "tsx tools/runTrustedBrowserBenchmark.ts --manual-template",
    "perf:root-cause-matrix": "tsx tools/runTrustedBrowserBenchmark.ts --mode=preview --profile=root-cause",
    "perf:trusted:report": "tsx tools/runTrustedBrowserBenchmark.ts --report-only",
    "perf:phase-profile:preview": "tsx tools/runBattleLoopPhaseProfile.ts --mode=preview --profile=phase",
    "perf:subsystem-matrix": "tsx tools/runBattleLoopPhaseProfile.ts --mode=preview --profile=subsystem",
    "perf:density-ladder": "tsx tools/runBattleLoopPhaseProfile.ts --mode=preview --profile=density",
    "perf:browser-gate": "tsx tools/runBattleLoopPhaseProfile.ts --mode=preview --profile=gate",
    "perf:v0110:report": "tsx tools/runBattleLoopPhaseProfile.ts --report-only",
    "perf:phase-profile": "tsx tools/runBattleLoopPhaseProfile.ts --mode=preview --profile=phase",
    "perf:allocation-audit": "tsx tools/runBattleLoopSchedulerRescue.ts --allocation-audit",
    "perf:idle-cost-matrix": "tsx tools/runBattleLoopSchedulerRescue.ts --idle-cost-matrix --mode=preview",
    "perf:spatial-query-profile": "tsx tools/runSpatialQueryProfile.ts --mode=preview",
    "perf:render-lifecycle-audit": "tsx tools/runRenderLifecycleAudit.ts --mode=preview",
    "perf:host-snapshot": "tsx tools/runHostEnvironmentCalibration.ts --host-snapshot",
    "perf:controls:preview": "tsx tools/runHostEnvironmentCalibration.ts --mode=preview",
    "perf:controls:headed": "tsx tools/runHostEnvironmentCalibration.ts --mode=preview --headed",
    "perf:trusted:clean-profile": "tsx tools/runHostEnvironmentCalibration.ts --clean-profile --mode=preview",
    "perf:controls:report": "tsx tools/runHostEnvironmentCalibration.ts --report-only",
    "playtest:act1": "tsx tools/runAct1PlayabilityTelemetry.ts",
    "playtest:sim": "tsx tools/runPlaytestSim.ts",
    "playtest:lab": "tsx tools/runPlaytestLab.ts",
    "playtest:watchpoints": "tsx tools/runPlaytestLab.ts",
    "playtest:profiles": "tsx tools/runPlaytestProfiles.ts",
    "playtest:lab:extended": "tsx tools/runPlaytestLab.ts --extended --runs=5",
    "playtest:watchpoints:extended": "tsx tools/runPlaytestLab.ts --extended --watchpoints-only --runs=5",
    "playtest:profiles:compare": "tsx tools/runPlaytestProfiles.ts --compare --runs=5",
    "playtest:lab:verify": "tsx tools/verifyPlaytestLabOutputs.ts",
    "playtest:controls": "tsx tools/runControlBehaviourLab.ts",
    "playtest:controls:extended": "tsx tools/runControlBehaviourLab.ts --extended --runs=5",
    "playtest:controls:verify": "tsx tools/verifyControlBehaviourLabOutputs.ts",
    "assets:prompts": "tsx tools/manual-asset-pipeline/generatePromptBook.ts",
    "assets:ui-kit": "tsx tools/manual-asset-pipeline/generateProceduralUiKit.ts",
    "assets:process-battle-sprites": "tsx tools/manual-asset-pipeline/processBattleSprites.ts",
    "assets:manifest": "tsx tools/manual-asset-pipeline/buildAssetManifest.ts",
    "assets:validate": "tsx tools/manual-asset-pipeline/validateAssets.ts",
    "assets:refresh": "npm run assets:process-battle-sprites && npm run assets:manifest && npm run assets:validate"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.10.2",
    "rollup-plugin-visualizer": "^7.0.1",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "vite": "^6.0.5",
    "vitest": "^2.1.8"
  }
}
